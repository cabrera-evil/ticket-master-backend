APP_NAME="La Cuponera SV"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
API_VERSION=1.0.0
API_DOCS_PUBLIC=true

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12
JWT_SECRET=secret
JWT_REFRESH_SECRET=refresh-secret

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=lacuponera
DB_USERNAME=lacuponera
DB_PASSWORD=secret

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@lacuponera.test"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_NAME="Administrador La Cuponera SV"
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@lacuponera.test
ADMIN_PASSWORD=Password123

CORS_ALLOWED_ORIGINS=*                          # * or comma-separated: http://localhost:3000,https://app.example.com
CORS_ALLOWED_METHODS=*                          # * or comma-separated: GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*                          # * or comma-separated: Content-Type,Authorization,X-Requested-With
CORS_EXPOSED_HEADERS=X-Token-Refreshed,X-New-Access-Token
CORS_MAX_AGE=0
CORS_SUPPORTS_CREDENTIALS=true
